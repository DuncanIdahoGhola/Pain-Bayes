        <Param val="intensities_list = []*3&amp;#10;ratings_list = []*3&amp;#10;accept_list = []*3&amp;#10;fired_list = []*3" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
