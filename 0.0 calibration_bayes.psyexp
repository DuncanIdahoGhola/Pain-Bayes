        <Param val="# Jitter waiting&amp;#10;wait1jitter = np.random.choice([2000, 2100, 2200, 2300, 2400, 2500])&amp;#10;# in secs&amp;#10;wait1jitter = wait1jitter/1000&amp;#10;ramp_phase = 1&amp;#10;# Log intensity&amp;#10;Ramp.addData('wait1_dur', wait1jitter)&amp;#10;&amp;#10;&amp;#10;&amp;#10;        &amp;#10;# Get the intensity&amp;#10;dgc['demand'] = int(shock_intensities[Ramp.thisN])&amp;#10;intensity = dgc['demand']&amp;#10;assert dgc['demand'] &lt; int(expInfo['fail_ma'])&amp;#10;&amp;#10;# Set shock&amp;#10;lib, _ = ds8r.init()&amp;#10;result = ds8r.set_ds8r_safe(lib, dgc)&amp;#10;&amp;#10;&amp;#10;# Log intensity&amp;#10;Ramp.addData('intensity', intensity)&amp;#10;&amp;#10;&amp;#10;if debug:&amp;#10;    wait_text = 'DEBUG: A shock of ' + str(dgc['demand']) + 'J would be delivered'&amp;#10;else:&amp;#10;    wait_text = ''&amp;#10;    &amp;#10;&amp;#10;&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
