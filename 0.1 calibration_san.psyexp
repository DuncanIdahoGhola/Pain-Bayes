        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="/* Syntax Error: Fix Python code */" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="metadata = fire_none_uncertainty_pulse(&amp;#10;    current_ma,&amp;#10;    ds5_config,&amp;#10;    output_dir=output_dir / &quot;waveforms&quot;,&amp;#10;    trial_label=trial_label,&amp;#10;)&amp;#10;thisExp.addData(&quot;phase&quot;, &quot;ramp&quot;)&amp;#10;thisExp.addData(&quot;ramp&quot;, ramps_loop.thisN + 1)&amp;#10;thisExp.addData(&quot;ramp_step&quot;, ramp_step_index)&amp;#10;thisExp.addData(&quot;intensity_ma&quot;, current_ma)&amp;#10;thisExp.addData(&quot;noise_condition&quot;, &quot;none&quot;)&amp;#10;for key, value in metadata.items():&amp;#10;    thisExp.addData(key, value)" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
