        <Param val="series_trial.push(series.thisN);&amp;#10;ramp_trial.push(ramp.thisN);&amp;#10;intensities_list.push(Number.parseFloat(intensity));&amp;#10;fired_list.push(Number.parseInt(fired));&amp;#10;response = confirm_resp.keys;&amp;#10;if ((response instanceof list)) {&amp;#10;    response = (response ? response.slice((- 1))[0] : null);&amp;#10;}&amp;#10;if ((((response === &quot;n&quot;) &amp;&amp; (series.thisN === (N_RAMPS - 1))) &amp;&amp; (fired === 1))) {&amp;#10;    last_ramp_tolerated_ma = Number.parseFloat(intensity);&amp;#10;}&amp;#10;if ((response === &quot;n&quot;)) {&amp;#10;    ramp.finished = 1;&amp;#10;}&amp;#10;if ((Number.parseFloat(intensity) &gt;= RAMP_MAX_MA)) {&amp;#10;    Ramp.finished = 1;&amp;#10;}&amp;#10;if ((curr_item_loc &gt;= 3)) {&amp;#10;    curr_item_loc = (- 1);&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="series_trial.append(series.thisN)&amp;#10;ramp_trial.append(ramp.thisN)&amp;#10;intensities_list.append(float(intensity))&amp;#10;fired_list.append(int(fired))&amp;#10;response = confirm_resp.keys&amp;#10;if isinstance(response, list):&amp;#10;    response = response[-1] if response else None&amp;#10;&amp;#10;if response == &quot;n&quot; and series.thisN == N_RAMPS - 1 and fired == 1:&amp;#10;    last_ramp_tolerated_ma = float(intensity)&amp;#10;&amp;#10;if response == &quot;n&quot;:&amp;#10;&amp;#10;    ramp.finished = 1&amp;#10;&amp;#10;if float(intensity) &gt;= RAMP_MAX_MA:&amp;#10;    Ramp.finished = 1&amp;#10;&amp;#10;if curr_item_loc &gt;= 3:&amp;#10;    curr_item_loc = -1" valType="extendedCode" updates="constant" name="End Routine"/>
